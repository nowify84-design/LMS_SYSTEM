# MySQL (XAMPP). Create .env from this file and set DATABASE_URL.
# Example: mysql://root:@localhost:3306/nowify_lms
DATABASE_URL="mysql://root:@localhost:3306/nowify_lms"

# Optional: Flask ML API (Phase 5+)
# FLASK_API_URL="http://127.0.0.1:5000"
# FLASK_API_KEY=""

# Optional: seed university_id list (one per line; # comments). Overrides Excel.
# SEED_UNIVERSITY_IDS_FILE="prisma/university_ids.txt"
# Optional: Excel path for seed IDs only (column student_id or first column).
# SEED_STUDENT_IDS_EXCEL_PATH="prisma/date_references_seed.xlsx"

# Session signing (required in production)
# NEXTAUTH_SECRET="generate-a-random-secret"
# SESSION_SECRET="generate-a-random-secret"
